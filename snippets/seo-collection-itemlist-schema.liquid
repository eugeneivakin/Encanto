{%- if collection and collection.products_count > 0 -%}
  {%- assign itemlist_id = canonical_url | append: '#itemlist' -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "@id": {{ itemlist_id | json }},
      "name": {{ collection.title | json }},
      "url": {{ canonical_url | json }},
      "numberOfItems": {{ collection.products.size | json }},
      "itemListOrder": "https://schema.org/ItemListOrderAscending",
      "itemListElement": [
        {%- for product in collection.products -%}
          {
            "@type": "ListItem",
            "position": {{ paginate.current_offset | plus: forloop.index | json }},
            "name": {{ product.title | strip | json }},
            "url": {{ product.url | prepend: request.origin | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}
