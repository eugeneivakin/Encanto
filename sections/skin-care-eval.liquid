<div id="section-{{ section.id }}" class="skin-eval-section {{ section.settings.custom_classes }}">
  <div class="skin-eval-wrapper">
    {% if section.settings.background_image != blank %}
      <div class="skin-eval-image">
        {{
          section.settings.background_image
          | image_url: width: 2000
          | image_tag: loading: 'lazy', alt: section.settings.background_image.alt
        }}
      </div>
    {% endif %}

    <div class="skin-eval-overlay"></div>

    <div class="skin-eval-content">
      {% if section.settings.subtitle != blank %}
        <p class="skin-eval-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="skin-eval-title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="skin-eval-description">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.secondary_text != blank %}
        <p class="skin-eval-secondary">{{ section.settings.secondary_text }}</p>
      {% endif %}

      <div class="skin-eval-buttons">
        {% if section.settings.button_1_text != blank %}
          <a
            href="{{ section.settings.button_1_link }}"
            class="skin-eval-btn skin-eval-btn-primary"
            {% if section.settings.button_1_link == blank %}
              role="button"
            {% endif %}
          >
            {{ section.settings.button_1_text }}
          </a>
        {% endif %}

        {% if section.settings.button_2_text != blank %}
          <a
            href="{{ section.settings.button_2_link }}"
            class="skin-eval-btn skin-eval-btn-secondary"
            {% if section.settings.button_2_link == blank %}
              role="button"
            {% endif %}
          >
            {{ section.settings.button_2_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .skin-eval-section {
    --overlay-opacity: 0.75;
    --content-max-width: 700px;
    --button-gap: 20px;
  }

  .skin-eval-wrapper {
    position: relative;
    width: 100%;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .skin-eval-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .skin-eval-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .skin-eval-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 60%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .skin-eval-content {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: var(--content-max-width);
    width: 100%;
  }

  .skin-eval-subtitle {
    margin: 0 0 20px;
    font-weight: 400;
    line-height: 1.4;
    letter-spacing: 0.5px;
  }

  .skin-eval-title {
    margin: 0 0 30px;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .skin-eval-description {
    margin: 0 0 30px;
    line-height: 1.6;
  }

  .skin-eval-description p {
    margin: 0 0 15px;
  }

  .skin-eval-description p:last-child {
    margin-bottom: 0;
  }

  .skin-eval-secondary {
    margin: 0 0 40px;
    line-height: 1.5;
  }

  .skin-eval-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--button-gap);
    justify-content: center;
    align-items: center;
  }

  .skin-eval-btn {
    display: inline-block;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .skin-eval-btn-primary,
  .skin-eval-btn-secondary {
    padding: 15px 35px;
  }

  @media screen and (max-width: 768px) {
    .skin-eval-wrapper {
      min-height: 400px;
    }

    .skin-eval-overlay {
      width: 100%;
    }

    .skin-eval-buttons {
      flex-direction: column;
      width: 100%;
    }

    .skin-eval-btn {
      width: 100%;
      max-width: 300px;
    }
  }

  @media screen and (max-width: 480px) {
    .skin-eval-wrapper {
      min-height: 350px;
    }

    .skin-eval-subtitle {
      margin-bottom: 15px;
    }

    .skin-eval-title {
      margin-bottom: 20px;
    }

    .skin-eval-description {
      margin-bottom: 20px;
    }

    .skin-eval-secondary {
      margin-bottom: 30px;
    }
  }
</style>

<style>
  #section-{{ section.id }} {
    background-color: {{ section.settings.section_background }};
  }

  #section-{{ section.id }} .skin-eval-wrapper {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    padding-left: {{ section.settings.padding_horizontal_desktop }}px;
    padding-right: {{ section.settings.padding_horizontal_desktop }}px;
    max-width: {{ section.settings.section_max_width }};
    margin-left: auto;
    margin-right: auto;
  }

  #section-{{ section.id }} .skin-eval-overlay {
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  #section-{{ section.id }} .skin-eval-content {
    padding-left: {{ section.settings.content_padding_horizontal }}px;
    padding-right: {{ section.settings.content_padding_horizontal }}px;
  }

  #section-{{ section.id }} .skin-eval-subtitle {
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.subtitle_size_desktop }}px;
  }

  #section-{{ section.id }} .skin-eval-title {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_desktop }}px;
  }

  #section-{{ section.id }} .skin-eval-description {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size_desktop }}px;
  }

  #section-{{ section.id }} .skin-eval-secondary {
    color: {{ section.settings.secondary_text_color }};
    font-size: {{ section.settings.secondary_text_size_desktop }}px;
  }

  #section-{{ section.id }} .skin-eval-btn-primary {
    background-color: {{ section.settings.button_1_bg_color }};
    color: {{ section.settings.button_1_text_color }};
    font-size: {{ section.settings.button_1_size_desktop }}px;
  }

  #section-{{ section.id }} .skin-eval-btn-primary:hover {
    background-color: {{ section.settings.button_1_bg_hover_color }};
    color: {{ section.settings.button_1_text_hover_color }};
  }

  #section-{{ section.id }} .skin-eval-btn-secondary {
    background-color: {{ section.settings.button_2_bg_color }};
    color: {{ section.settings.button_2_text_color }};
    font-size: {{ section.settings.button_2_size_desktop }}px;
  }

  #section-{{ section.id }} .skin-eval-btn-secondary:hover {
    background-color: {{ section.settings.button_2_bg_hover_color }};
    color: {{ section.settings.button_2_text_hover_color }};
  }

  @media screen and (max-width: 768px) {
    #section-{{ section.id }} .skin-eval-wrapper {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: {{ section.settings.padding_horizontal_mobile }}px;
      padding-right: {{ section.settings.padding_horizontal_mobile }}px;
    }

    #section-{{ section.id }} .skin-eval-subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
    }

    #section-{{ section.id }} .skin-eval-title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    #section-{{ section.id }} .skin-eval-description {
      font-size: {{ section.settings.description_size_mobile }}px;
    }

    #section-{{ section.id }} .skin-eval-secondary {
      font-size: {{ section.settings.secondary_text_size_mobile }}px;
    }

    #section-{{ section.id }} .skin-eval-btn-primary {
      font-size: {{ section.settings.button_1_size_mobile }}px;
    }

    #section-{{ section.id }} .skin-eval-btn-secondary {
      font-size: {{ section.settings.button_2_size_mobile }}px;
    }
  }
</style>

