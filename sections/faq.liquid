<style>
  .faq-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px;
  }

  .faq-section__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .faq-section__heading {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 12px;
  }

  .faq-section__description {
    font-size: 17px;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  /* Group */
  .faq-group {
    margin-bottom: 40px;
  }

  .faq-group__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  .faq-group__icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .faq-group__icon svg {
    width: 100%;
    height: 100%;
  }

  .faq-group__title {
    font-size: 20px;
    font-weight: 700;
    margin: 0;
  }

  /* Question item */
  .faq-item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }

  .faq-item__button {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
    font-family: inherit;
  }

  .faq-item__question-wrap {
    flex: 1;
    min-width: 0;
  }

  .faq-item__caption {
    font-size: 13px;
    opacity: 0.5;
    margin-bottom: 4px;
    font-weight: 400;
  }

  .faq-item__question {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0;
  }

  .faq-item__chevron {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq-item.active .faq-item__chevron {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }

  .faq-item__answer-inner {
    padding: 0 0 20px;
  }

  .faq-item__answer-text {
    font-size: 15px;
    line-height: 1.7;
    opacity: 0.8;
    margin: 0;
  }

  .faq-item__answer-image {
    margin-top: 16px;
    border-radius: 12px;
    overflow: hidden;
  }

  .faq-item__answer-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .faq-section {
      padding: 40px 16px;
    }

    .faq-section__header {
      margin-bottom: 32px;
    }

    .faq-section__heading {
      font-size: 28px;
    }

    .faq-group__title {
      font-size: 18px;
    }

    .faq-item__question {
      font-size: 15px;
    }
  }
</style>

<div class="faq-section color-{{ section.settings.color_scheme }}"
  {% if section.settings.custom_id != blank %}id="{{ section.settings.custom_id }}"{% endif %}
  data-section-id="{{ section.id }}"
>
  {%- if section.settings.heading != blank or section.settings.description != blank -%}
    <div class="faq-section__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="faq-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="faq-section__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- assign current_group_open = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'group' -%}
      {%- if current_group_open -%}
        </div>
      {%- endif -%}
      <div class="faq-group" {{ block.shopify_attributes }}>
        <div class="faq-group__header">
          {%- if block.settings.icon == 'shipping' -%}
            <div class="faq-group__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
            </div>
          {%- elsif block.settings.icon == 'store' -%}
            <div class="faq-group__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            </div>
          {%- elsif block.settings.icon == 'return' -%}
            <div class="faq-group__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
            </div>
          {%- elsif block.settings.icon == 'product' -%}
            <div class="faq-group__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
          {%- elsif block.settings.icon == 'question' -%}
            <div class="faq-group__icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
          {%- endif -%}
          <h3 class="faq-group__title">{{ block.settings.title }}</h3>
        </div>
      {%- assign current_group_open = true -%}

    {%- elsif block.type == 'question' -%}
      <div class="faq-item" {{ block.shopify_attributes }}>
        <button class="faq-item__button" aria-expanded="false">
          <div class="faq-item__question-wrap">
            {%- if block.settings.caption != blank -%}
              <div class="faq-item__caption">{{ block.settings.caption }}</div>
            {%- endif -%}
            <p class="faq-item__question">{{ block.settings.question }}</p>
          </div>
          <svg class="faq-item__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </button>
        <div class="faq-item__answer">
          <div class="faq-item__answer-inner">
            <div class="faq-item__answer-text">{{ block.settings.answer }}</div>
            {%- if block.settings.image != blank -%}
              <div class="faq-item__answer-image">
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  sizes: '(max-width: 749px) 100vw, 800px'
                }}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- if current_group_open -%}
    </div>
  {%- endif -%}
</div>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const buttons = section.querySelectorAll('.faq-item__button');

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        const item = this.closest('.faq-item');
        const answer = item.querySelector('.faq-item__answer');
        const isActive = item.classList.contains('active');

        if (isActive) {
          item.classList.remove('active');
          answer.style.maxHeight = '0';
          this.setAttribute('aria-expanded', 'false');
        } else {
          item.classList.add('active');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer", "custom.popup"]
  },
  "settings": [
    {
      "type": "text",
      "id": "custom_id",
      "label": "Section ID",
      "info": "Custom ID for anchor links"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    }
  ],
  "blocks": [
    {
      "type": "group",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "General"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "question",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "store", "label": "Store" },
            { "value": "return", "label": "Returns" },
            { "value": "product", "label": "Product" },
            { "value": "question", "label": "Question" }
          ]
        }
      ]
    },
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "info": "Small label above the question (optional)"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How does it work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer goes here.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "group",
          "settings": {
            "title": "Shipping",
            "icon": "shipping"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping takes 5-7 business days.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Yes, we ship worldwide.</p>"
          }
        },
        {
          "type": "group",
          "settings": {
            "title": "Product",
            "icon": "product"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How do I use the grounding sheet?",
            "answer": "<p>Simply place it on your bed and connect the grounding cord to your outlet's ground port.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
