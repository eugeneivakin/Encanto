{%- liquid
  assign section_id = section.id
  assign image_position = section.settings.image_position
  assign mobile_layout = section.settings.mobile_layout
  assign custom_class = section.settings.custom_class
-%}

<section
  id="section-{{ section_id }}"
  class="image-text-block {{ custom_class }}"
>
  <div class="image-text-block__container">
    <div class="image-text-block__wrapper image-text-block__wrapper--image-{{ image_position }} image-text-block__wrapper--mobile-{{ mobile_layout }}">
      <div class="image-text-block__image-col">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 400 }} 400w,
                    {{ section.settings.image | image_url: width: 600 }} 600w,
                    {{ section.settings.image | image_url: width: 800 }} 800w,
                    {{ section.settings.image | image_url: width: 1000 }} 1000w,
                    {{ section.settings.image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
            class="image-text-block__image"
          >
        {%- else -%}
          <div class="image-text-block__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
      <div class="image-text-block__content-col">
        <div class="image-text-block__content">
          {%- if section.settings.subtitle != blank -%}
            <p class="image-text-block__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="image-text-block__title">{{ section.settings.title }}</h2>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <div class="image-text-block__description rte">{{ section.settings.description }}</div>
          {%- endif -%}
          {%- if section.settings.button_label != blank -%}
            <a
              {% if section.settings.button_link != blank %}
                href="{{ section.settings.button_link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              class="image-text-block__button button"
            >
              {{ section.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .image-text-block {
    --itb-gap: 30px;
    --itb-content-max-width: 540px;
  }

  .image-text-block__container {
    width: 100%;
    margin: 0 auto;
  }

  .image-text-block__wrapper {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .image-text-block__wrapper--image-right {
    flex-direction: row-reverse;
  }

  .image-text-block__image-col,
  .image-text-block__content-col {
    width: 100%;
  }

  .image-text-block__image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .image-text-block__placeholder {
    background-color: #f5f5f5;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-text-block__placeholder .placeholder-svg {
    width: 50%;
    height: auto;
  }

  .image-text-block__content {
    max-width: var(--itb-content-max-width);
  }

  .image-text-block__subtitle {
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  .image-text-block__title {
    margin: 0 0 15px;
    line-height: 1.2;
  }

  .image-text-block__description {
    margin: 0 0 25px;
    line-height: 1.6;
  }

  .image-text-block__description:last-child {
    margin-bottom: 0;
  }

  .image-text-block__button {
    display: inline-block;
    padding: 14px 32px;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .image-text-block__button:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .image-text-block__wrapper--mobile-image-first {
      flex-direction: column;
    }

    .image-text-block__wrapper--mobile-content-first {
      flex-direction: column-reverse;
    }

    .image-text-block__content {
      margin: 0 auto;
      text-align: center;
      padding-top: 30px;
    }
  }

  @media screen and (min-width: 750px) {
    .image-text-block__image-col,
    .image-text-block__content-col {
      width: 50%;
    }

    .image-text-block__content-col {
      display: flex;
      justify-content: center;
    }

    .image-text-block__wrapper--image-left .image-text-block__content-col {
      padding-left: var(--itb-gap);
    }

    .image-text-block__wrapper--image-right .image-text-block__content-col {
      padding-right: var(--itb-gap);
    }
  }
</style>

<style>
  #section-{{ section_id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.padding_left_mobile }}px;
    padding-right: {{ section.settings.padding_right_mobile }}px;
  }

  #section-{{ section_id }} .image-text-block__container {
    max-width: {{ section.settings.max_width }};
  }

  #section-{{ section_id }} .image-text-block__image {
    border-radius: {{ section.settings.image_border_radius }}px;
  }

  #section-{{ section_id }} .image-text-block__subtitle {
    color: {{ section.settings.subtitle_color }};
    font-size: {{ section.settings.subtitle_size_mobile }}px;
  }

  #section-{{ section_id }} .image-text-block__title {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_mobile }}px;
  }

  #section-{{ section_id }} .image-text-block__description {
    color: {{ section.settings.description_color }};
    font-size: {{ section.settings.description_size_mobile }}px;
  }

  #section-{{ section_id }} .image-text-block__button {
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_color }};
    border-radius: {{ section.settings.button_border_radius }}px;
  }

  @media screen and (min-width: 750px) {
    #section-{{ section_id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: {{ section.settings.padding_left_desktop }}px;
      padding-right: {{ section.settings.padding_right_desktop }}px;
    }

    #section-{{ section_id }} .image-text-block__subtitle {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
    }

    #section-{{ section_id }} .image-text-block__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }

    #section-{{ section_id }} .image-text-block__description {
      font-size: {{ section.settings.description_size_desktop }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Image Text Block",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Image settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Image border radius",
      "default": 0
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (Desktop)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "image-first",
          "label": "Image first"
        },
        {
          "value": "content-first",
          "label": "Content first"
        }
      ],
      "default": "image-first"
    },
    {
      "type": "header",
      "content": "Content settings"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size (Desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size (Mobile)",
      "default": 12
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#666666"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Image with text"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 18,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Title size (Desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Title size (Mobile)",
      "default": 28
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>"
    },
    {
      "type": "range",
      "id": "description_size_desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Description size (Mobile)",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button settings"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Button border radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "max_width",
      "label": "Section max width",
      "default": "1400px",
      "info": "Use px, %, or other CSS units"
    },
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding right",
      "default": 20
    },
    {
      "type": "header",
      "content": "Padding (Mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding left",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding right",
      "default": 16
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class"
    }
  ],
  "presets": [
    {
      "name": "Image Text Block"
    }
  ]
}
{% endschema %}
